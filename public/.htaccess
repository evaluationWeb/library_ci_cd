<IfModule mod_rewrite.c>
    RewriteEngine On

    # Servir directement les fichiers et dossiers existants
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Rediriger toutes les autres requetes vers le front controller
    RewriteRule ^ index.php [QSA,L]
</IfModule>
